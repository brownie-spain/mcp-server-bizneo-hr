# Bizneo HR API Configuration
# Get your API token from the Bizneo HR application settings
BIZNEO_API_TOKEN=your_api_token_here

# Bizneo HR API base URL (default: https://connect.bizneo.com/hcm)
BIZNEO_API_BASE_URL=https://connect.bizneo.com/hcm

# Rate limiting: maximum requests per second allowed by your API plan
# Check your Bizneo HR plan limits. Common values: 5, 10, 20
BIZNEO_RATE_LIMIT_RPS=10

# Rate limiting: maximum concurrent requests
BIZNEO_RATE_LIMIT_CONCURRENT=5

# ─── MCP Server transport ───────────────────────────────────────────────────
# Transport mode: stdio (local process) or http (remote/OpenAI agents)
# Use 'http' for deployment, 'stdio' for local Claude Desktop / Claude Code
MCP_TRANSPORT=http

# HTTP transport settings (only used when MCP_TRANSPORT=http)
MCP_PORT=3000
MCP_HOST=0.0.0.0

# Allowed CORS origins. Use '*' for public access or a comma-separated list
# to restrict access (e.g. 'https://app.openai.com,https://api.openai.com')
MCP_CORS_ORIGINS=*

# Log level: error | warn | info | debug
LOG_LEVEL=info
